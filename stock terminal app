<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>360° Stock Intelligence Terminal — Free, No API Key</title>
<meta name="description" content="Institutional-grade stock analysis for NSE/BSE stocks. Free. No API key. Real data from Yahoo Finance + TradingView."/>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg0:#04040a; --bg1:#080812; --bg2:#0d0d1a; --bg3:#121222;
  --bg4:#181830; --border:#1e1e38; --borderB:#2a2a4a;
  --t0:#eeeeff; --t1:#9999cc; --t2:#5555aa; --t3:#33335a;
  --gold:#e8b84b; --goldD:#6b4f1a; --goldG:rgba(232,184,75,.1);
  --green:#00e676; --greenD:#003d1f; --greenG:rgba(0,230,118,.08);
  --red:#ff3860; --redD:#4d0018; --redG:rgba(255,56,96,.08);
  --blue:#4db8ff; --blueG:rgba(77,184,255,.08);
  --cyan:#00e5ff; --purple:#b388ff;
  --mono:'Space Mono',monospace; --head:'Syne',sans-serif;
  --r4:4px; --r6:6px; --r8:8px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--mono);background:var(--bg0);color:var(--t0);min-height:100vh;overflow-x:hidden}

/* Ambient background */
body::before{content:'';position:fixed;inset:0;
  background:radial-gradient(ellipse 80% 60% at 20% -10%,rgba(232,184,75,.04) 0%,transparent 60%),
             radial-gradient(ellipse 60% 80% at 80% 110%,rgba(77,184,255,.03) 0%,transparent 60%);
  pointer-events:none;z-index:0}

/* Fine grid */
body::after{content:'';position:fixed;inset:0;
  background-image:linear-gradient(rgba(232,184,75,.015) 1px,transparent 1px),
                   linear-gradient(90deg,rgba(232,184,75,.015) 1px,transparent 1px);
  background-size:60px 60px;pointer-events:none;z-index:0}

/* ── HEADER ── */
.hdr{position:sticky;top:0;z-index:200;
  background:rgba(4,4,10,.95);border-bottom:1px solid var(--border);
  backdrop-filter:blur(20px);padding:0 20px}
.hdr-inner{max-width:1500px;margin:0 auto;display:flex;align-items:center;gap:16px;height:54px}

.logo{display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0}
.logo-mark{width:34px;height:34px;background:linear-gradient(135deg,var(--gold),#c8941a);
  clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
  display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#000}
.logo-txt{display:flex;flex-direction:column}
.logo-name{font-family:var(--head);font-size:13px;font-weight:800;color:var(--gold);letter-spacing:.1em}
.logo-tag{font-size:8px;color:var(--t2);letter-spacing:.15em;margin-top:1px}

.hdr-sep{width:1px;height:26px;background:var(--border);flex-shrink:0}

/* Search */
.srch-wrap{flex:1;max-width:500px;position:relative}
.srch-input{width:100%;background:var(--bg3);border:1px solid var(--borderB);border-radius:var(--r4);
  padding:9px 100px 9px 40px;font-family:var(--mono);font-size:12px;color:var(--t0);
  outline:none;letter-spacing:.06em;transition:border-color .2s,box-shadow .2s;text-transform:uppercase}
.srch-input::placeholder{color:var(--t3);text-transform:none;letter-spacing:0}
.srch-input:focus{border-color:var(--gold);box-shadow:0 0 0 3px var(--goldG)}
.srch-ico{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--t2);font-size:14px;pointer-events:none}
.srch-btn{position:absolute;right:4px;top:4px;bottom:4px;
  background:var(--gold);color:#000;border:none;border-radius:3px;
  padding:0 14px;font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.1em;
  cursor:pointer;transition:background .15s;white-space:nowrap}
.srch-btn:hover{background:#f5c84a}
.srch-btn:disabled{background:var(--goldD);color:#555;cursor:not-allowed}

.hdr-right{margin-left:auto;display:flex;align-items:center;gap:14px;flex-shrink:0}
.live-pill{display:flex;align-items:center;gap:5px;background:var(--greenG);
  border:1px solid var(--greenD);border-radius:100px;padding:3px 10px;font-size:9px;
  color:var(--green);letter-spacing:.1em}
.live-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:blink 1.4s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.clk{font-size:10px;color:var(--t2);letter-spacing:.06em;font-family:var(--mono)}

/* ── MAIN ── */
.main{max-width:1500px;margin:0 auto;padding:20px 20px 60px;position:relative;z-index:1}

/* ── WELCOME ── */
.welcome{min-height:76vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:18px}
.w-orb{width:110px;height:110px;border-radius:50%;
  background:conic-gradient(from 0deg,var(--gold),var(--green),var(--blue),var(--gold));
  display:flex;align-items:center;justify-content:center;animation:spin 8s linear infinite;
  box-shadow:0 0 60px rgba(232,184,75,.2)}
@keyframes spin{to{transform:rotate(360deg)}}
.w-orb-inner{width:90px;height:90px;border-radius:50%;background:var(--bg0);display:flex;align-items:center;justify-content:center;font-size:36px}
.w-title{font-family:var(--head);font-size:30px;font-weight:800;letter-spacing:-.01em;max-width:600px}
.w-title span{color:var(--gold)}
.w-desc{font-size:12px;color:var(--t1);max-width:540px;line-height:2;letter-spacing:.03em}
.w-tags{display:flex;flex-wrap:wrap;gap:8px;justify-content:center}
.w-tag{background:var(--bg3);border:1px solid var(--borderB);border-radius:100px;
  padding:6px 16px;font-size:11px;color:var(--t1);cursor:pointer;letter-spacing:.06em;
  transition:all .18s}
.w-tag:hover{border-color:var(--gold);color:var(--gold);background:var(--goldG)}

.sources-badge{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-top:4px}
.src-chip{display:flex;align-items:center;gap:5px;background:var(--bg2);
  border:1px solid var(--border);border-radius:4px;padding:5px 12px;font-size:10px;color:var(--t2);letter-spacing:.06em}
.src-chip span{font-size:12px}

.committee-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;max-width:820px;width:100%}
.comm-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r6);padding:14px 12px;text-align:left}
.cc-role{font-size:8px;color:var(--gold);letter-spacing:.14em;text-transform:uppercase;margin-bottom:4px}
.cc-name{font-family:var(--head);font-size:12px;font-weight:700;color:var(--t0);line-height:1.4}
.cc-style{font-size:9px;color:var(--t2);margin-top:3px;font-style:italic}

/* ── LOADING ── */
.loading{min-height:70vh;display:none;flex-direction:column;align-items:center;justify-content:center;gap:20px}
.load-term{background:var(--bg1);border:1px solid var(--border);border-radius:var(--r8);
  padding:22px 28px;width:100%;max-width:560px;font-size:11px;line-height:2.1;letter-spacing:.04em}
.ld{color:var(--t3)}
.ld.run{color:var(--gold)}
.ld.run::before{content:'▶ '}
.ld.ok{color:var(--green)}
.ld.ok::before{content:'✓ '}
.load-bar-bg{width:100%;max-width:560px;height:2px;background:var(--bg3);border-radius:1px;overflow:hidden}
.load-bar{height:100%;background:linear-gradient(90deg,var(--gold),var(--green));width:0;
  transition:width .4s ease;border-radius:1px}

/* ── ERROR ── */
.err-state{min-height:50vh;display:none;flex-direction:column;align-items:center;justify-content:center;gap:14px;text-align:center}
.err-ico{font-size:52px}
.err-title{font-family:var(--head);font-size:20px;color:var(--red)}
.err-msg{font-size:12px;color:var(--t1);max-width:480px;line-height:1.8}
.err-tips{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r6);
  padding:14px 18px;text-align:left;max-width:480px;width:100%;font-size:11px;color:var(--t1);line-height:2}

/* ── DASHBOARD ── */
.dash{display:none}
.dash.on{display:block}

/* ── TICKER HERO ── */
.hero{background:var(--bg1);border:1px solid var(--borderB);border-radius:var(--r8);
  padding:18px 22px;margin-bottom:14px;display:flex;align-items:center;gap:22px;flex-wrap:wrap;
  animation:slideIn .35s ease}
@keyframes slideIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
.hero-sym{font-family:var(--head);font-size:34px;font-weight:800;color:var(--gold);letter-spacing:.04em;line-height:1}
.hero-name{font-size:12px;color:var(--t1);margin-top:3px;letter-spacing:.03em}
.hero-exch{font-size:9px;color:var(--t3);margin-top:2px;letter-spacing:.1em}
.hero-sep{width:1px;height:56px;background:var(--border);flex-shrink:0}
.hero-price{font-family:var(--head);font-size:30px;font-weight:700;letter-spacing:.02em}
.hero-chg{font-size:13px;font-weight:700;letter-spacing:.06em;margin-top:3px}
.up{color:var(--green)} .dn{color:var(--red)}
.hero-stats{display:flex;gap:22px;flex-wrap:wrap;margin-left:auto}
.hstat{display:flex;flex-direction:column;align-items:flex-end;gap:2px}
.hstat-l{font-size:8px;color:var(--t3);letter-spacing:.12em;text-transform:uppercase}
.hstat-v{font-size:13px;font-weight:700;color:var(--t0)}
.data-src{font-size:9px;color:var(--t3);letter-spacing:.08em;margin-left:auto;align-self:flex-end}

/* ── VERDICT BANNER ── */
.verdict{border-radius:var(--r8);padding:16px 22px;margin-bottom:14px;
  display:flex;align-items:center;gap:18px;border:1px solid;animation:slideIn .4s ease .05s both}
.verdict.G{background:var(--greenG);border-color:var(--green)}
.verdict.A{background:var(--goldG);border-color:var(--gold)}
.verdict.R{background:var(--redG);border-color:var(--red)}
.v-badge{font-family:var(--head);font-size:11px;font-weight:800;letter-spacing:.18em;
  padding:7px 16px;border-radius:var(--r4);border:2px solid;white-space:nowrap;flex-shrink:0}
.verdict.G .v-badge{color:var(--green);border-color:var(--green);background:var(--greenG);text-shadow:0 0 16px var(--green)}
.verdict.A .v-badge{color:var(--gold);border-color:var(--gold);background:var(--goldG);text-shadow:0 0 16px var(--gold)}
.verdict.R .v-badge{color:var(--red);border-color:var(--red);background:var(--redG);text-shadow:0 0 16px var(--red)}
.v-txt{flex:1}
.v-head{font-family:var(--head);font-size:15px;font-weight:700;margin-bottom:4px}
.v-rat{font-size:11px;color:var(--t1);line-height:1.7;letter-spacing:.02em}
.v-score-wrap{text-align:right;flex-shrink:0}
.v-score-l{font-size:8px;color:var(--t3);letter-spacing:.12em;margin-bottom:4px}
.v-score{font-family:var(--head);font-size:26px;font-weight:800}
.verdict.G .v-score{color:var(--green)}
.verdict.A .v-score{color:var(--gold)}
.verdict.R .v-score{color:var(--red)}
.v-score-sub{font-size:9px;color:var(--t2);letter-spacing:.06em}

/* ── PANEL ── */
.panel{background:var(--bg1);border:1px solid var(--border);border-radius:var(--r8);overflow:hidden;margin-bottom:14px}
.panel-hd{display:flex;align-items:center;justify-content:space-between;
  padding:11px 16px;border-bottom:1px solid var(--border);background:var(--bg2)}
.panel-ttl{font-size:9px;font-weight:700;letter-spacing:.14em;color:var(--gold);
  display:flex;align-items:center;gap:7px;text-transform:uppercase}
.panel-chip{font-size:8px;letter-spacing:.1em;color:var(--t2);background:var(--bg0);
  border:1px solid var(--border);border-radius:100px;padding:2px 9px}
.panel-bd{padding:16px}

/* ── GRID ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:14px}

/* ── METRIC CARDS ── */
.mcards{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.mcard{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r4);padding:10px 12px}
.mc-l{font-size:8px;color:var(--t3);letter-spacing:.12em;text-transform:uppercase;margin-bottom:5px}
.mc-v{font-size:18px;font-weight:700;letter-spacing:.02em}
.mc-sub{font-size:9px;color:var(--t2);margin-top:2px}
.mc-v.good{color:var(--green)} .mc-v.bad{color:var(--red)} .mc-v.neutral{color:var(--gold)}
.mc-v.na{color:var(--t3)}

/* ── TECH INDICATORS ── */
.ind-row{display:flex;align-items:center;justify-content:space-between;
  padding:8px 0;border-bottom:1px solid var(--border);font-size:11px}
.ind-row:last-child{border-bottom:none}
.ind-name{color:var(--t2);letter-spacing:.03em}
.ind-val{font-weight:700;font-size:12px}
.ind-sig{font-size:8px;padding:2px 8px;border-radius:100px;letter-spacing:.1em;font-weight:700}
.bull{background:var(--greenG);color:var(--green);border:1px solid var(--greenD)}
.bear{background:var(--redG);color:var(--red);border:1px solid var(--redD)}
.neut{background:var(--goldG);color:var(--gold);border:1px solid var(--goldD)}

/* ── CHART ── */
.chart-box{width:100%;height:460px;overflow:hidden}

/* ── FIB TABLE ── */
.fib-grid{display:grid;gap:6px}
.fib-row{display:flex;align-items:center;gap:10px;background:var(--bg2);
  border:1px solid var(--border);border-radius:var(--r4);padding:8px 12px}
.fib-pct{font-size:9px;color:var(--gold);letter-spacing:.08em;width:50px;flex-shrink:0}
.fib-bar{flex:1;height:4px;background:var(--bg3);border-radius:2px;overflow:hidden}
.fib-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--gold),var(--green))}
.fib-price{font-size:12px;font-weight:700;color:var(--t0);text-align:right;flex-shrink:0;min-width:80px}
.fib-zone{font-size:8px;padding:1px 6px;border-radius:100px;flex-shrink:0}
.fib-zone.sup{background:var(--greenG);color:var(--green);border:1px solid var(--greenD)}
.fib-zone.res{background:var(--redG);color:var(--red);border:1px solid var(--redD)}
.fib-zone.cur{background:var(--blueG);color:var(--blue);border:1px solid #1a3d5a}

/* ── DCF TABLE ── */
.dcf-tbl{width:100%;border-collapse:collapse;font-size:11px}
.dcf-tbl th{text-align:center;font-size:8px;letter-spacing:.1em;color:var(--t3);
  padding:8px;border-bottom:1px solid var(--border);background:var(--bg2);font-weight:400}
.dcf-tbl th:first-child{text-align:left;padding-left:14px}
.dcf-tbl td{text-align:center;padding:8px;border-bottom:1px solid var(--border);
  border-right:1px solid var(--border);color:var(--t1);font-size:11px}
.dcf-tbl td:first-child{text-align:left;color:var(--t2);font-size:9px;letter-spacing:.06em;padding-left:14px}
.dcf-tbl tr:last-child td{border-bottom:none}
.dcf-hl{background:var(--goldG)!important;color:var(--gold)!important;font-weight:700!important}
.dcf-gr{color:var(--green)!important;font-weight:700!important}

/* ── ALLOC PANEL ── */
.alloc-panel{background:linear-gradient(135deg,var(--bg1),rgba(232,184,75,.03));border-color:var(--goldD)}
.alloc-total{font-family:var(--head);font-size:34px;font-weight:800;color:var(--gold)}
.alloc-sub{font-size:11px;color:var(--t2);margin-top:3px;margin-bottom:16px;letter-spacing:.03em}
.tranches{display:flex;flex-direction:column;gap:8px;margin-bottom:14px}
.tranche{display:flex;align-items:center;gap:12px;background:var(--bg2);
  border:1px solid var(--border);border-radius:var(--r4);padding:11px 14px}
.tr-num{width:24px;height:24px;border-radius:50%;background:var(--gold);
  color:#000;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.tr-info{flex:1}
.tr-ttl{font-size:11px;font-weight:700;color:var(--t0);margin-bottom:2px;letter-spacing:.03em}
.tr-det{font-size:10px;color:var(--t2)}
.tr-amt{flex-shrink:0;text-align:right}
.tr-inr{font-size:14px;font-weight:700;color:var(--gold)}
.tr-shr{font-size:9px;color:var(--t2);margin-top:1px}

.zones{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.zone{border-radius:var(--r4);padding:11px;text-align:center;border:1px solid}
.zone.en{border-color:#1a3d5a;background:var(--blueG)}
.zone.sl{border-color:var(--redD);background:var(--redG)}
.zone.tg{border-color:var(--greenD);background:var(--greenG)}
.zone-l{font-size:8px;letter-spacing:.12em;margin-bottom:5px}
.zone.en .zone-l{color:var(--blue)}
.zone.sl .zone-l{color:var(--red)}
.zone.tg .zone-l{color:var(--green)}
.zone-p{font-size:14px;font-weight:700;margin-bottom:2px}
.zone-s{font-size:9px;color:var(--t2)}

/* ── RISK TABLE ── */
.risk-tbl{width:100%;border-collapse:collapse;font-size:11px}
.risk-tbl th{text-align:left;font-size:8px;letter-spacing:.1em;color:var(--t3);
  padding:7px 10px;border-bottom:1px solid var(--border);font-weight:400;background:var(--bg2)}
.risk-tbl td{padding:9px 10px;border-bottom:1px solid var(--border);color:var(--t1);
  font-size:11px;vertical-align:top;line-height:1.5;letter-spacing:.02em}
.risk-tbl tr:last-child td{border-bottom:none}
.risk-tbl tr:hover td{background:var(--bg2)}
.rl{display:inline-block;padding:2px 8px;border-radius:100px;font-size:8px;
  font-weight:700;letter-spacing:.1em;font-family:var(--mono)}
.rl.H{background:var(--redG);color:var(--red);border:1px solid var(--redD)}
.rl.M{background:var(--goldG);color:var(--gold);border:1px solid var(--goldD)}
.rl.L{background:var(--greenG);color:var(--green);border:1px solid var(--greenD)}

/* ── NARRATIVE ── */
.narr-sec{margin-bottom:16px}
.narr-sec:last-child{margin-bottom:0}
.narr-lbl{font-size:8px;color:var(--gold);letter-spacing:.14em;text-transform:uppercase;
  margin-bottom:8px;display:flex;align-items:center;gap:8px}
.narr-lbl::after{content:'';flex:1;height:1px;background:var(--border)}
.narr-txt{font-size:12px;color:var(--t1);line-height:1.85;letter-spacing:.02em}
.narr-consensus{font-size:13px;color:var(--t0);padding:14px 16px;
  background:var(--bg2);border-radius:var(--r6);border:1px solid var(--borderB);line-height:1.8}

/* ── MOAT BARS ── */
.moat-item{margin-bottom:12px}
.moat-item:last-child{margin-bottom:0}
.moat-row{display:flex;justify-content:space-between;margin-bottom:4px;font-size:11px;color:var(--t1)}
.moat-score{font-weight:700;color:var(--t0)}
.moat-bar{height:5px;background:var(--bg3);border-radius:3px;overflow:hidden}
.moat-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--gold),var(--green));transition:width 1.2s ease}

/* ── SCORE RING ── */
.score-ring-wrap{display:flex;flex-direction:column;align-items:center;gap:8px;padding:14px 0}
.score-ring{width:120px;height:120px;border-radius:50%;display:flex;align-items:center;
  justify-content:center;flex-direction:column;border:3px solid var(--border);position:relative;
  background:var(--bg2)}
.score-ring::before{content:'';position:absolute;inset:-3px;border-radius:50%;
  background:conic-gradient(var(--gold) var(--pct,0%),var(--border) 0%);
  -webkit-mask:radial-gradient(farthest-side,transparent calc(100% - 6px),black calc(100% - 6px));
  mask:radial-gradient(farthest-side,transparent calc(100% - 6px),black calc(100% - 6px))}
.score-val{font-family:var(--head);font-size:28px;font-weight:800;color:var(--gold)}
.score-max{font-size:9px;color:var(--t2)}
.score-lbl{font-size:9px;color:var(--t2);letter-spacing:.1em}

/* ── DATA SOURCES FOOTER ── */
.sources-footer{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r6);
  padding:12px 16px;margin-top:14px;font-size:10px;color:var(--t2);line-height:1.8;letter-spacing:.03em}
.sources-footer strong{color:var(--t1)}

/* ── FOOTER ── */
.footer{border-top:1px solid var(--border);padding:14px 20px;
  display:flex;align-items:center;justify-content:space-between;
  font-size:10px;color:var(--t3);position:relative;z-index:1}
.footer-disc{max-width:700px;line-height:1.7;letter-spacing:.02em}

/* ── RESPONSIVE ── */
