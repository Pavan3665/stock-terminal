    {n:'MACD Signal',v:macdSig?.toFixed(2)||'N/A',sig:macd!=null&&macdSig!=null?macd>macdSig?'BULLISH CROSS':'BEARISH CROSS':'N/A',sc:macd!=null&&macdSig!=null?macd>macdSig?'bull':'bear':'neut'},
