    {n:'200-Day MA',v:ma200?P(ma200):'N/A',sig:price&&ma200?price>ma200?'ABOVE':'BELOW':'N/A',sc:price&&ma200?price>ma200?'bull':'bear':'neut'},
    {n:'Bollinger Band',v:bbPos?`${bbPos}% of band`:'N/A',sig:bbPos?+bbPos<20?'NEAR LOWER':+bbPos>80?'NEAR UPPER':'MID ZONE':'N/A',sc:bbPos?+bbPos<30?'bull':+bbPos>75?'bear':'neut':'neut'},
    {n:'BB Upper',v:bb.upper?P(bb.upper):'N/A',sig:'RESISTANCE',sc:'bear'},
    {n:'BB Lower',v:bb.lower?P(bb.lower):'N/A',sig:'SUPPORT',sc:'bull'},
  ].map(i=>`<div class="ind-row"><span class="ind-name">${i.n}</span><span class="ind-val">${i.v}</span><span class="ind-sig ${i.sc}">${i.sig}</span></div>`).join('');
  
  // ── FIBONACCI
  const fpEl=document.getElementById('fibPanel');
  if(fib&&hi52&&lo52){
    const levels=[
      {pct:'100% (High)',p:fib.high,z:'res'},{pct:'78.6%',p:fib.r5,z:'res'},
      {pct:'61.8% (Golden)',p:fib.r4,z:'sup'},{pct:'50.0%',p:fib.r3,z:'sup'},
      {pct:'38.2%',p:fib.r2,z:'sup'},{pct:'23.6%',p:fib.r1,z:'sup'},
      {pct:'0% (Low)',p:fib.low,z:'sup'},
    ];
    const range=hi52-lo52;
    fpEl.innerHTML=`<div style="font-size:10px;color:var(--t2);margin-bottom:10px;letter-spacing:.04em">52W Range: ${P(lo52)} → ${P(hi52)} | Current: ${P(price)}</div>
    <div class="fib-grid">${levels.map(l=>{
      const pct=range>0?Math.round((l.p-lo52)/range*100):50;
      const isCur=price&&Math.abs(price-l.p)/l.p<0.05;
      return`<div class="fib-row">
        <span class="fib-pct">${l.pct}</span>
        <div class="fib-bar"><div class="fib-fill" style="width:${pct}%"></div></div>
        <span class="fib-price">${P(l.p)}</span>
        <span class="fib-zone ${isCur?'cur':l.z}">${isCur?'CURRENT':l.z==='res'?'RESIST':'SUPPORT'}</span>
      </div>`;
    }).join('')}</div>`;
  } else {
    fpEl.innerHTML=`<div style="color:var(--t2);font-size:12px;text-align:center;padding:20px">52-week range data unavailable.<br/>TradingView chart shows Fibonacci overlays.</div>`;
  }
  
  // ── MOAT
  document.getElementById('moatCard').innerHTML=moat.map(m=>`
    <div class="moat-item">
      <div class="moat-row"><span>${m.cat}</span><span class="moat-score">${m.score}/100</span></div>
      <div class="moat-bar"><div class="moat-fill" style="width:${m.score}%"></div></div>
    </div>`).join('');
  
  // ── SCORE BREAKDOWN
  const avgMoat=Math.round(moat.reduce((a,m)=>a+m.score,0)/moat.length);
  document.getElementById('scoreBreak').innerHTML=`
    <div class="score-ring-wrap">
      <div class="score-ring" style="--pct:${score}%">
        <div class="score-val">${score}</div>
        <div class="score-max">/ 100</div>
      </div>
      <div class="score-lbl">${verdict==='G'?'BUY ZONE':verdict==='A'?'WATCH ZONE':'AVOID ZONE'}</div>
    </div>
    <div style="margin-top:12px">${breakdown.map(b=>`
      <div class="ind-row">
        <span class="ind-name">${b.label}</span>
        <span class="ind-val">${b.score}/${b.max}</span>
        <span class="ind-sig ${b.score/b.max>=0.65?'bull':b.score/b.max>=0.4?'neut':'bear'}">${b.score/b.max>=0.65?'STRONG':b.score/b.max>=0.4?'FAIR':'WEAK'}</span>
      </div>`).join('')}
      <div class="ind-row">
        <span class="ind-name">Avg Moat Score</span>
        <span class="ind-val">${avgMoat}/100</span>
        <span class="ind-sig ${avgMoat>=65?'bull':avgMoat>=45?'neut':'bear'}">${avgMoat>=65?'WIDE':avgMoat>=45?'MODERATE':'NARROW'}</span>
      </div>
    </div>`;
  
  // ── DCF
  const years=['FY25E','FY26E','FY27E','FY28E','FY29E'];
  document.getElementById('dcfTbl').innerHTML=`
    <thead><tr><th>Metric</th>${years.map(y=>`<th>${y}</th>`).join('')}</tr></thead>
    <tbody>
      <tr><td>FCF / Share (₹)</td>${dcf.rows.fcf.map((v,i)=>`<td class="${i===4?'dcf-hl':''}">${v.toFixed(2)}</td>`).join('')}</tr>
      <tr><td>Growth Rate</td>${dcf.rows.growth.map(v=>`<td>${v}</td>`).join('')}</tr>
      <tr><td>Present Value</td>${dcf.rows.pv.map((v,i)=>`<td class="${i===4?'dcf-hl':''}">${v.toFixed(2)}</td>`).join('')}</tr>
      <tr><td>Sum of PV (₹)</td><td colspan="3" class="dcf-hl">${dcf.totalPV.toFixed(2)}</td><td colspan="2" style="color:var(--t2);font-size:10px">Terminal Value: ₹${dcf.terminalVal.toFixed(2)}</td></tr>
      <tr><td>INTRINSIC VALUE / SHARE</td><td colspan="2" class="dcf-hl" style="font-size:14px">${P(dcf.intrinsic)}</td><td colspan="3" class="dcf-gr">vs Current: ${dcf.upside!=null?(dcf.upside>=0?'+':'')+dcf.upside+'%':N/A}</td></tr>
      <tr><td>MoS Entry (20% disc.)</td><td colspan="2" style="color:var(--gold);font-weight:700">${P(dcf.mos)}</td><td colspan="3" style="color:var(--t2);font-size:10px">WACC: ${dcf.wacc} | Terminal g: ${dcf.tg} | Discount: 20%</td></tr>
    </tbody>`;
  document.getElementById('dcfNote').innerHTML=`<strong style="color:var(--gold)">DCF Assumptions:</strong> Base FCF/share derived from Yahoo Finance free cash flow ÷ shares outstanding. Growth rates: ${dcf.rows.growth.join(', ')}. WACC 12% (India equity risk premium). Terminal growth 6% (India long-term GDP). Intrinsic value: ${P(dcf.intrinsic)}. At current price ${P(price)}, the stock trades at a ${dcf.upside!=null?Math.abs(dcf.upside)+'% '+(dcf.upside>=0?'discount to':'premium over')+' intrinsic value':'N/A'}. The 20% Margin of Safety entry point is ${P(dcf.mos)} — below this level, risk/reward is highly favorable. Note: DCF is highly sensitive to growth assumptions; treat as one input, not a definitive price target.`;
  
  // ── ALLOCATION
  document.getElementById('allocSub').textContent=`Staggered deployment for ${base} | Current Price: ${P(price)}`;
  document.getElementById('tranches').innerHTML=[alloc.t1,alloc.t2,alloc.t3].map((t,i)=>`
    <div class="tranche">
      <div class="tr-num">${i+1}</div>
      <div class="tr-info"><div class="tr-ttl">${t.trigger}</div><div class="tr-det">${t.detail}</div></div>
      <div class="tr-amt"><div class="tr-inr">${t.amt}</div><div class="tr-shr">${t.shares}</div></div>
    </div>`).join('');
  document.getElementById('zones').innerHTML=`
    <div class="zone en"><div class="zone-l">ENTRY ZONE</div><div class="zone-p">${alloc.entry}</div><div class="zone-s">12–15 month view</div></div>
    <div class="zone sl"><div class="zone-l">STOP LOSS</div><div class="zone-p">${alloc.stop}</div><div class="zone-s">${alloc.stopNote}</div></div>
    <div class="zone tg"><div class="zone-l">PROFIT TARGET</div><div class="zone-p">${alloc.target}</div><div class="zone-s">${alloc.targetNote}</div></div>`;
  
  // ── RISKS
  document.getElementById('riskBody').innerHTML=risks.map(r=>`
    <tr><td>${r.r}</td><td><span class="rl ${r.l}">${r.l==='H'?'HIGH':r.l==='M'?'MED':'LOW'}</span></td><td>${r.m}</td></tr>`).join('');
  
  // ── NARRATIVE
  document.getElementById('narr').innerHTML=`
    <div class="narr-sec"><div class="narr-lbl">🏰 Value Investor — Competitive Moat &amp; Management</div><div class="narr-txt">${narr.moat}</div></div>
    <div class="narr-sec"><div class="narr-lbl">📋 Fundamental Analyst — P&amp;L, Balance Sheet &amp; DCF</div><div class="narr-txt">${narr.fundamentals}</div></div>
    <div class="narr-sec"><div class="narr-lbl">⚡ Technical Analyst — Price Action &amp; Momentum</div><div class="narr-txt">${narr.technical}</div></div>
    <div class="narr-sec"><div class="narr-lbl">💰 Portfolio Constructor — ₹15,000 Sizing &amp; Risk</div><div class="narr-txt">${narr.portfolio}</div></div>
    <div class="narr-sec"><div class="narr-lbl">🏛 Committee Consensus — Final Verdict</div><div class="narr-consensus">${narr.consensus}</div></div>`;
  
  // ── DATA SOURCES
  document.getElementById('srcFooter').innerHTML=`<strong>Data Sources:</strong> Price &amp; Fundamentals via <strong>Yahoo Finance</strong> (${YTICKER}) through public CORS proxy (no API key) · Live chart &amp; technical signals via <strong>TradingView</strong> (free widget) · RSI, MACD, Moving Averages, Bollinger Bands, and Fibonacci levels <strong>computed client-side</strong> from 1-year daily OHLC price history · DCF model computed in-browser · Last refreshed: ${new Date().toLocaleString('en-IN',{timeZone:'Asia/Kolkata'})} IST`;
  
  // ── SHOW DASHBOARD
  document.getElementById('dash').classList.add('on');
  window.scrollTo({top:0,behavior:'smooth'});
}

// ─────────────────────────────────────────────────────────────────
// MAIN GO FUNCTION
// ─────────────────────────────────────────────────────────────────
async function go(){
  const raw=document.getElementById('si').value.trim();
  if(!raw)return document.getElementById('si').focus();
  
  const {base,yahoo,tv}=parseTicker(raw);
  TICKER=base; YTICKER=yahoo; TV_SYM=tv;
  
  const btn=document.getElementById('sb');
  btn.disabled=true; btn.textContent='LOADING...';
  
  // Reset loading
  for(let i=0;i<10;i++){const el=document.getElementById('l'+i);if(el){el.className='ld';}}
  document.getElementById('ldBar').style.width='0';
  
  // Show loading
  document.getElementById('wState').style.display='none';
  document.getElementById('errState').style.display='none';
  document.getElementById('dash').classList.remove('on');
  show('ldState');
  
  const anim=animLoad();
  
  try{
    // Parallel fetch
    const [summary,history]=await Promise.all([
      fetchYahooSummary(yahoo),
      fetchYahooHistory(yahoo)
    ]);
    
    await anim;
    show(null);
    renderDash(base,summary,history,tv);
    
  }catch(err){
    await anim.catch(()=>{});
    document.getElementById('ldState').style.display='none';
    document.getElementById('errState').style.display='flex';
    document.getElementById('errMsg').textContent=err.message||'Failed to fetch market data. Please try again.';
  }
  
  btn.disabled=false; btn.textContent='ANALYZE ▶';
}
</script>
