// ─────────────────────────────────────────────────────────────────
// ALLOCATION PLAN
// ─────────────────────────────────────────────────────────────────
function buildAllocation(price,tech,verdict){
  const p=price;
  const ma50=tech.ma50||p*0.95;
  const ma200=tech.ma200||p*0.88;
  const fib618=tech.fib618||p*0.92;
  
  const t1p=Math.round(p*1.000*100)/100;
  const t2p=Math.round(Math.min(ma50,fib618,p*0.94)*100)/100;
  const t3p=Math.round(Math.min(ma200,p*0.87)*100)/100;
  const stop=Math.round(t3p*0.92*100)/100;
  const target=Math.round(p*(verdict==='G'?1.35:verdict==='A'?1.25:1.18)*100)/100;
  
  const s1=Math.floor(6000/t1p), s2=Math.floor(5500/t2p), s3=Math.floor(3500/t3p);
  
  return{
    t1:{trigger:'TRANCHE 1 — Deploy Immediately',detail:`At/near ₹${t1p} (current market price)`,amt:'₹6,000',shares:`≈ ${s1} shares @ ₹${t1p}`},
    t2:{trigger:'TRANCHE 2 — Pullback Entry',detail:`On dip to ₹${t2p} (50-DMA / Fib 0.618 zone)`,amt:'₹5,500',shares:`≈ ${s2} shares @ ₹${t2p}`},
    t3:{trigger:'TRANCHE 3 — Deep Value Entry',detail:`If corrects to ₹${t3p} (200-DMA confluence)`,amt:'₹3,500',shares:`≈ ${s3} shares @ ₹${t3p}`},
    entry:`₹${t2p}–${t1p}`,
    stop:`₹${stop}`,
    target:`₹${target}`,
    avgEntry:`₹${Math.round((t1p+t2p+t3p)/3*100)/100}`,
    stopNote:'~8% below avg entry',
    targetNote:`${verdict==='G'?'+35%':'+25%'} upside, 18–24M`
  };
}

