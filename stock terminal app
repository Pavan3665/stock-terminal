    bar.style.width=`${(i+1)*10}%`;
    await sleep(300+Math.random()*300);
    if(el){el.classList.remove('run');el.classList.add('ok');}
  }
}

const sleep=ms=>new Promise(r=>setTimeout(r,ms));

// ─────────────────────────────────────────────────────────────────
// PARSE TICKER INPUT
// ─────────────────────────────────────────────────────────────────
function parseTicker(raw){
  let t=raw.trim().toUpperCase().replace(/\s+/g,'');
  // Handle NSE: or BSE: prefix
  if(t.startsWith('NSE:'))t=t.slice(4);
  if(t.startsWith('BSE:'))t=t.slice(4)+'_BSE';
  
  let isBSE=t.endsWith('.BO')||t.endsWith('_BSE');
  if(t.endsWith('_BSE'))t=t.slice(0,-4);
  
  const base=t.replace('.NS','').replace('.BO','');
  const ySuffix=isBSE?'.BO':'.NS';
  const tvExch=isBSE?'BSE':'NSE';
  
  return {base, yahoo:`${base}${ySuffix}`, tv:`${tvExch}:${base}`};
}

// ─────────────────────────────────────────────────────────────────
// CORS PROXIES
// ─────────────────────────────────────────────────────────────────
const PROXIES=[
  url=>`https://corsproxy.io/?${encodeURIComponent(url)}`,
  url=>`https://api.allorigins.win/raw?url=${encodeURIComponent(url)}`,
  url=>`https://proxy.cors.sh/${url}`,
];

async function fetchWithProxy(url){
  for(const proxy of PROXIES){
    try{
      const res=await fetch(proxy(url),{signal:AbortSignal.timeout(10000)});
      if(res.ok){
        const data=await res.json();
        if(data&&!data.error)return data;
      }
    }catch(e){continue;}
  }
  throw new Error('All proxies failed for: '+url);
}

// ─────────────────────────────────────────────────────────────────
// YAHOO FINANCE DATA FETCH
// ─────────────────────────────────────────────────────────────────
async function fetchYahooSummary(ySym){
  const url=`https://query1.finance.yahoo.com/v10/finance/quoteSummary/${ySym}?modules=price,summaryDetail,defaultKeyStatistics,financialData,incomeStatementHistory,balanceSheetHistory,cashflowStatementHistory`;
  const data=await fetchWithProxy(url);
  const r=data?.quoteSummary?.result?.[0];
  if(!r)throw new Error(`No data found for ${ySym}. Check if ticker is listed on NSE/BSE.`);
  return r;
}

async function fetchYahooHistory(ySym){
  const url=`https://query1.finance.yahoo.com/v8/finance/chart/${ySym}?interval=1d&range=1y`;
  const data=await fetchWithProxy(url);
  const r=data?.chart?.result?.[0];
  if(!r)throw new Error('Could not fetch price history');
  
  const closes=r.indicators?.quote?.[0]?.close||[];
  const highs=r.indicators?.quote?.[0]?.high||[];
  const lows=r.indicators?.quote?.[0]?.low||[];
  const volumes=r.indicators?.quote?.[0]?.volume||[];
  const timestamps=r.timestamp||[];
  
  // Filter out nulls
  const valid=closes.map((c,i)=>({c,h:highs[i],l:lows[i],v:volumes[i],t:timestamps[i]})).filter(x=>x.c!=null);
  return valid;
}

// ─────────────────────────────────────────────────────────────────
// TECHNICAL CALCULATIONS
// ─────────────────────────────────────────────────────────────────
function calcRSI(closes,period=14){
  if(closes.length<period+1)return null;
  let gains=0,losses=0;
  for(let i=1;i<=period;i++){
    const d=closes[i]-closes[i-1];
    d>0?gains+=d:losses+=Math.abs(d);
  }
  let avgG=gains/period,avgL=losses/period;
  for(let i=period+1;i<closes.length;i++){
    const d=closes[i]-closes[i-1];
    avgG=(avgG*(period-1)+(d>0?d:0))/period;
    avgL=(avgL*(period-1)+(d<0?Math.abs(d):0))/period;
  }
  if(avgL===0)return 100;
  const rs=avgG/avgL;
  return Math.round((100-100/(1+rs))*10)/10;
}

function calcEMA(data,period){
  const k=2/(period+1);
  let ema=data.slice(0,period).reduce((a,b)=>a+b,0)/period;
  const result=[...Array(period-1).fill(null),ema];
  for(let i=period;i<data.length;i++){
    ema=data[i]*k+ema*(1-k);
    result.push(Math.round(ema*100)/100);
  }
  return result;
}

function calcMACD(closes){
  if(closes.length<26)return{macd:null,signal:null,hist:null};
  const ema12=calcEMA(closes,12);
  const ema26=calcEMA(closes,26);
  const macdLine=ema12.map((v,i)=>v!=null&&ema26[i]!=null?Math.round((v-ema26[i])*100)/100:null);
  const validMacd=macdLine.filter(v=>v!=null);
  const signalLine=calcEMA(validMacd,9);
  const lastM=macdLine.findLast(v=>v!=null);
  const lastS=signalLine[signalLine.length-1];
  const hist=lastM!=null&&lastS!=null?Math.round((lastM-lastS)*100)/100:null;
  return{macd:lastM,signal:lastS,hist};
}

function calcMA(closes,period){
  if(closes.length<period)return null;
  const slice=closes.slice(-period);
  return Math.round(slice.reduce((a,b)=>a+b,0)/period*100)/100;
}

function calcBollinger(closes,period=20){
  if(closes.length<period)return{upper:null,mid:null,lower:null};
  const slice=closes.slice(-period);
  const mid=slice.reduce((a,b)=>a+b,0)/period;
  const variance=slice.reduce((a,b)=>a+Math.pow(b-mid,2),0)/period;
  const std=Math.sqrt(variance);
  return{upper:Math.round((mid+2*std)*100)/100,mid:Math.round(mid*100)/100,lower:Math.round((mid-2*std)*100)/100};
}

function calcFibLevels(high,low){
  const diff=high-low;
  return{
    r1:Math.round((low+diff*0.236)*100)/100,
    r2:Math.round((low+diff*0.382)*100)/100,
    r3:Math.round((low+diff*0.500)*100)/100,
    r4:Math.round((low+diff*0.618)*100)/100,
    r5:Math.round((low+diff*0.786)*100)/100,
    high:Math.round(high*100)/100,
    low:Math.round(low*100)/100,
  };
}

// ─────────────────────────────────────────────────────────────────
// COMPOSITE SCORING ENGINE
// ─────────────────────────────────────────────────────────────────
function computeScore(f,tech){
  let s=0,breakdown=[];
  
  // VALUATION (30 pts)
  const pe=f.pe,peg=f.peg,pb=f.pb;
  let valScore=0;
  if(pe){
    if(pe<15)valScore+=12;
    else if(pe<25)valScore+=7;
    else if(pe<40)valScore+=3;
    else valScore+=0;
  } else valScore+=5; // neutral if missing
  if(peg){if(peg<1)valScore+=10;else if(peg<2)valScore+=5;else valScore+=0;}
  else valScore+=4;
  if(pb){if(pb<2)valScore+=8;else if(pb<5)valScore+=4;else valScore+=0;}
  else valScore+=3;
  breakdown.push({label:'Valuation',score:Math.min(valScore,30),max:30});
  s+=Math.min(valScore,30);
  
  // QUALITY (35 pts)
  const roe=f.roe*100,pm=f.pm*100,de=f.de,rg=f.rg*100;
  let qScore=0;
  if(roe){if(roe>20)qScore+=12;else if(roe>12)qScore+=7;else if(roe>6)qScore+=3;}
  else qScore+=5;
  if(pm){if(pm>20)qScore+=10;else if(pm>10)qScore+=6;else if(pm>5)qScore+=3;}
  else qScore+=4;
  if(de!=null){if(de<30)qScore+=8;else if(de<100)qScore+=5;else if(de<200)qScore+=2;}
  else qScore+=4;
  if(rg){if(rg>15)qScore+=5;else if(rg>5)qScore+=3;}
  else qScore+=2;
  breakdown.push({label:'Quality & Moat',score:Math.min(qScore,35),max:35});
  s+=Math.min(qScore,35);
  
  // MOMENTUM (35 pts)
  let mScore=0;
  const rsi=tech.rsi,price=tech.price,ma50=tech.ma50,ma200=tech.ma200,macd=tech.macd,macdSig=tech.macdSig;
  if(rsi!=null){
    if(rsi<30)mScore+=14; // oversold = buy
    else if(rsi>=30&&rsi<=55)mScore+=12; // healthy
    else if(rsi>55&&rsi<=70)mScore+=7;
    else mScore+=2; // overbought
  } else mScore+=6;
  if(price&&ma50&&ma200){
    if(price>ma50&&price>ma200)mScore+=10;
    else if(price>ma200)mScore+=5;
    else mScore+=0;
  } else mScore+=5;
  if(macd!=null&&macdSig!=null){
    if(macd>macdSig)mScore+=6;
    else mScore+=2;
  } else mScore+=3;
  if(macd!=null){if(macd>0)mScore+=5;else mScore+=1;}
  else mScore+=2;
  breakdown.push({label:'Momentum',score:Math.min(mScore,35),max:35});
  s+=Math.min(mScore,35);
  
  return{total:Math.min(Math.round(s),100),breakdown};
}

function verdictFromScore(score){
  if(score>=62)return'G';
  if(score>=40)return'A';
  return'R';
}

// ─────────────────────────────────────────────────────────────────
// DCF MODEL
// ─────────────────────────────────────────────────────────────────
function buildDCF(f,price){
  const fcf=f.fcf||0,shares=f.shares||1;
  const fcfPS=fcf>0?Math.round(fcf/shares*100)/100:null;
  const wacc=0.12, terminal=0.06;
  const growthRates=[0.12,0.12,0.10,0.08,0.07];
  
  let base=fcfPS||(price*0.04); // fallback: ~4% FCF yield assumption
  let rows={fcf:[],growth:[],pv:[]};
  let totalPV=0;
  let yr=base;
  
  for(let i=0;i<5;i++){
    yr=Math.round(yr*(1+growthRates[i])*100)/100;
    const pv=Math.round(yr/Math.pow(1+wacc,i+1)*100)/100;
    rows.fcf.push(yr);
    rows.growth.push(`${(growthRates[i]*100).toFixed(0)}%`);
    rows.pv.push(pv);
    totalPV+=pv;
  }
  
  const terminalVal=Math.round((rows.fcf[4]*(1+terminal)/(wacc-terminal))/Math.pow(1+wacc,5)*100)/100;
  const intrinsic=Math.round((totalPV+terminalVal)*100)/100;
  const mos=Math.round(intrinsic*0.80*100)/100;
  const upside=price>0?Math.round(((intrinsic-price)/price)*100):null;
  
  return{rows,totalPV:Math.round(totalPV*100)/100,terminalVal,intrinsic,mos,upside,wacc:'12%',tg:'6%'};
}

// ─────────────────────────────────────────────────────────────────
// MOAT SCORING
// ─────────────────────────────────────────────────────────────────
function moatScore(f){
  const gm=(f.gm||0)*100, om=(f.om||0)*100, roe=(f.roe||0)*100, de=f.de||100, rg=(f.rg||0)*100;
  return[
    {cat:'Brand & Pricing Power',score:gm>40?88:gm>25?72:gm>15?55:38},
    {cat:'Management Quality',score:roe>20?90:roe>14?74:roe>8?55:35},
    {cat:'Operating Efficiency',score:om>20?85:om>12?68:om>6?50:30},
    {cat:'Balance Sheet Strength',score:de<30?88:de<80?70:de<150?52:30},
    {cat:'Revenue Growth Trend',score:rg>15?88:rg>8?72:rg>3?55:35},
    {cat:'Switching Costs / Moat',score:roe>18&&gm>25?80:roe>12?60:45},
  ];
}

// ─────────────────────────────────────────────────────────────────
// RISK REGISTER
// ─────────────────────────────────────────────────────────────────
function buildRisks(f,score){
  const risks=[];
  const de=f.de||0, pe=f.pe||0, rg=(f.rg||0)*100;
  
  if(de>150)risks.push({r:'High Leverage Risk',l:'H',m:'D/E ratio elevated. Monitor refinancing risk; rising rates could squeeze margins. Ensure ICR > 3x.'});
  else if(de>80)risks.push({r:'Moderate Leverage',l:'M',m:'Leverage manageable but watch free cash flow generation vs. debt servicing obligations.'});
  else risks.push({r:'Balance Sheet Risk',l:'L',m:'Low debt levels provide financial flexibility. Strong buffer for downturns or opportunistic acquisitions.'});
  
  if(pe>45)risks.push({r:'Valuation Risk',l:'H',m:'Rich P/E leaves little room for earnings misses. Any guidance cut could trigger 15–25% derating.'});
  else if(pe>25)risks.push({r:'Valuation Risk',l:'M',m:'P/E at premium — priced for growth. Earnings delivery crucial. Consider staggered entry to manage timing risk.'});
  else risks.push({r:'Valuation Risk',l:'L',m:'Trading at reasonable multiples. Margin of safety exists. Limited downside from valuation alone.'});
  
  risks.push({r:'Macro / Rate Risk',l:'M',m:'RBI rate trajectory and global risk-off episodes can compress multiples. Hedge with stop-loss discipline.'});
  risks.push({r:'Competitive Risk',l:rg>10?'L':'M',m:rg>10?'Strong revenue growth signals competitive position intact. Watch for new entrants.':'Slowing growth may indicate competitive pressure or market saturation. Monitor market share trends.'});
  risks.push({r:'Regulatory Risk',l:'L',m:'India regulatory environment broadly supportive. Sector-specific policy changes remain a tail risk. Diversify across sectors.'});
  
  return risks;
}

