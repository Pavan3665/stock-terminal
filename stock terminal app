// ─────────────────────────────────────────────────────────────────
// LOADING ANIMATION
// ─────────────────────────────────────────────────────────────────
async function animLoad(){
  const steps=['l0','l1','l2','l3','l4','l5','l6','l7','l8','l9'];
  const bar=document.getElementById('ldBar');
  for(let i=0;i<steps.length;i++){
